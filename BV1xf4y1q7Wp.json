{
  "video": "/mnt/nas/share/home/lxh/wav/BV1xf4y1q7Wp.mp4",
  "wav": "/mnt/nas/share/home/lxh/wav/BV1xf4y1q7Wp.wav",
  "language": "zh",
  "duration": 156.608,
  "segments": [
    {
      "start": 0.0,
      "end": 1.82,
      "text": "一个大男人在车站碎碎念"
    },
    {
      "start": 1.82,
      "end": 3.76,
      "text": "不断向人讲述曾经的过往"
    },
    {
      "start": 3.76,
      "end": 4.8,
      "text": "他就是阿甘"
    },
    {
      "start": 4.8,
      "end": 6.7,
      "text": "那前半生可谓波澜壮阔"
    },
    {
      "start": 6.7,
      "end": 8.06,
      "text": "小时候欢迎腿急"
    },
    {
      "start": 8.06,
      "end": 9.74,
      "text": "每日穿着腿套行走"
    },
    {
      "start": 9.74,
      "end": 11.26,
      "text": "加上智商只有75"
    },
    {
      "start": 11.26,
      "end": 13.24,
      "text": "没有小朋友愿意和他一起玩耍"
    },
    {
      "start": 13.24,
      "end": 13.84,
      "text": "很幸运"
    },
    {
      "start": 13.84,
      "end": 15.26,
      "text": "他遇到了生命中的天使"
    },
    {
      "start": 15.26,
      "end": 15.7,
      "text": "珍妮"
    },
    {
      "start": 15.7,
      "end": 17.24,
      "text": "一天被同龄人欺负"
    },
    {
      "start": 17.24,
      "end": 18.68,
      "text": "在珍妮的呼喊声中"
    },
    {
      "start": 18.68,
      "end": 20.0,
      "text": "阿甘摆脱了腿套"
    },
    {
      "start": 20.0,
      "end": 20.9,
      "text": "奔跑舞飞"
    },
    {
      "start": 20.9,
      "end": 28.72,
      "text": "小时候被自行车追赶"
    },
    {
      "start": 28.72,
      "end": 30.22,
      "text": "长大了被汽车追赶"
    },
    {
      "start": 30.9,
      "end": 34.0,
      "text": "合一于超快的奔跑速度"
    },
    {
      "start": 34.0,
      "end": 35.26,
      "text": "他加入了橄榄球队"
    },
    {
      "start": 35.26,
      "end": 37.18,
      "text": "并且借此顺利进入大学"
    },
    {
      "start": 37.18,
      "end": 39.32,
      "text": "还因此被肯尼迪总统接见"
    },
    {
      "start": 39.32,
      "end": 40.82,
      "text": "毕业后顺利参军"
    },
    {
      "start": 40.82,
      "end": 41.86,
      "text": "在军队中"
    },
    {
      "start": 41.86,
      "end": 43.1,
      "text": "遇到了好友布巴"
    },
    {
      "start": 43.1,
      "end": 45.36,
      "text": "一个一心只想着补相的年轻人"
    },
    {
      "start": 45.36,
      "end": 47.16,
      "text": "两人在单中卫的带领下"
    },
    {
      "start": 47.16,
      "end": 48.02,
      "text": "参加越战"
    },
    {
      "start": 48.02,
      "end": 49.4,
      "text": "在一次遭遇战中"
    },
    {
      "start": 49.4,
      "end": 51.1,
      "text": "阿甘救出了多位战友"
    },
    {
      "start": 51.1,
      "end": 53.04,
      "text": "但是好友布巴不幸离世"
    },
    {
      "start": 53.04,
      "end": 54.3,
      "text": "在医院养伤期间"
    },
    {
      "start": 54.3,
      "end": 55.58,
      "text": "还学会了乒乓球"
    },
    {
      "start": 55.58,
      "end": 56.54,
      "text": "回国后"
    },
    {
      "start": 56.54,
      "end": 58.52,
      "text": "阿甘被约翰逊总统接见"
    },
    {
      "start": 58.52,
      "end": 60.26,
      "text": "也遇见了流浪球的珍妮"
    },
    {
      "start": 60.26,
      "end": 62.5,
      "text": "珍妮总是为了梦想四处流浪"
    },
    {
      "start": 62.5,
      "end": 64.08,
      "text": "不愿意停下自己的脚步"
    },
    {
      "start": 64.08,
      "end": 65.34,
      "text": "阿甘在乒乓球"
    },
    {
      "start": 65.34,
      "end": 66.68,
      "text": "表现出极高的天赋"
    },
    {
      "start": 66.68,
      "end": 68.4,
      "text": "并代表美国前往中国"
    },
    {
      "start": 68.4,
      "end": 69.76,
      "text": "参加乒乓球交流"
    },
    {
      "start": 69.76,
      "end": 70.56,
      "text": "回国后"
    },
    {
      "start": 70.56,
      "end": 71.98,
      "text": "被尼克松总统接见"
    },
    {
      "start": 71.98,
      "end": 73.0,
      "text": "但是不久后"
    },
    {
      "start": 73.0,
      "end": 74.42,
      "text": "就收到了退役批文"
    },
    {
      "start": 74.42,
      "end": 75.56,
      "text": "退役后"
    },
    {
      "start": 75.56,
      "end": 77.26,
      "text": "阿甘去了布巴的故乡"
    },
    {
      "start": 77.26,
      "end": 78.46,
      "text": "带着所有的积蓄"
    },
    {
      "start": 78.46,
      "end": 79.72,
      "text": "买下了一艘船"
    },
    {
      "start": 79.72,
      "end": 80.84,
      "text": "在海上补相"
    },
    {
      "start": 80.84,
      "end": 82.14,
      "text": "替好友实现遗愿"
    },
    {
      "start": 82.14,
      "end": 83.2,
      "text": "在越战中"
    },
    {
      "start": 83.2,
      "end": 84.58,
      "text": "失去双腿的单中卫"
    },
    {
      "start": 84.58,
      "end": 86.26,
      "text": "和阿甘在海上漂流"
    },
    {
      "start": 86.26,
      "end": 88.06,
      "text": "像极了捷克船长欧威尔"
    },
    {
      "start": 88.06,
      "end": 89.72,
      "text": "一场狂风暴雨后"
    },
    {
      "start": 89.72,
      "end": 91.8,
      "text": "只有阿甘的捕杀船轻饮一难"
    },
    {
      "start": 91.8,
      "end": 93.56,
      "text": "成功垄断了海下市场"
    },
    {
      "start": 93.56,
      "end": 95.54,
      "text": "阿甘因此赚得浮满波满"
    },
    {
      "start": 95.54,
      "end": 96.62,
      "text": "回到故乡"
    },
    {
      "start": 96.62,
      "end": 98.38,
      "text": "每日只是割草和等待"
    },
    {
      "start": 98.38,
      "end": 99.38,
      "text": "终于有一天"
    },
    {
      "start": 99.38,
      "end": 100.36,
      "text": "他等到了珍妮"
    },
    {
      "start": 100.36,
      "end": 102.04,
      "text": "经历了各种困苦的珍妮"
    },
    {
      "start": 102.04,
      "end": 103.0,
      "text": "变得很沉默"
    },
    {
      "start": 103.0,
      "end": 104.86,
      "text": "一段愉快的相处后"
    },
    {
      "start": 104.86,
      "end": 107.22,
      "text": "珍妮再次踏上了流浪之路"
    },
    {
      "start": 107.22,
      "end": 108.48,
      "text": "失落无助的阿甘"
    },
    {
      "start": 108.48,
      "end": 109.38,
      "text": "独自奔跑"
    },
    {
      "start": 109.38,
      "end": 111.38,
      "text": "就这样他跑了三年"
    },
    {
      "start": 111.38,
      "end": 113.94,
      "text": "渐渐他有了一群奔跑的伙伴"
    },
    {
      "start": 113.94,
      "end": 115.12,
      "text": "直到有一天"
    },
    {
      "start": 115.12,
      "end": 116.82,
      "text": "他明白了一个人生哲理"
    },
    {
      "start": 118.06,
      "end": 125.5,
      "text": "刚学会放下了阿甘"
    },
    {
      "start": 125.5,
      "end": 127.68,
      "text": "回到家就收到了珍妮的来信"
    },
    {
      "start": 127.68,
      "end": 128.92,
      "text": "再一次见到珍妮"
    },
    {
      "start": 128.92,
      "end": 130.34,
      "text": "发现她改变了很多"
    },
    {
      "start": 130.34,
      "end": 132.06,
      "text": "而且还有一个漂亮的小孩子"
    },
    {
      "start": 132.06,
      "end": 133.5,
      "text": "单纯三年的阿甘"
    },
    {
      "start": 133.5,
      "end": 136.02,
      "text": "终于和珍妮步入了婚姻的殿堂"
    },
    {
      "start": 136.02,
      "end": 138.24,
      "text": "然而珍妮不走后就因病去世"
    },
    {
      "start": 138.24,
      "end": 139.98,
      "text": "只留下丈夫和孩子"
    },
    {
      "start": 139.98,
      "end": 141.38,
      "text": "两个人相依为命"
    },
    {
      "start": 141.38,
      "end": 142.94,
      "text": "电影开头和结尾"
    },
    {
      "start": 142.94,
      "end": 144.64,
      "text": "都有一片飘落的羽毛"
    },
    {
      "start": 144.64,
      "end": 146.68,
      "text": "开场的时候阿甘收起了羽毛"
    },
    {
      "start": 146.68,
      "end": 148.04,
      "text": "于是很快见到了阿甘"
    },
    {
      "start": 148.04,
      "end": 149.0,
      "text": "和珍妮"
    },
    {
      "start": 149.0,
      "end": 150.98,
      "text": "结尾羽毛随风而逝"
    },
    {
      "start": 150.98,
      "end": 153.22,
      "text": "珍妮也离他而去"
    },
    {
      "start": 153.22,
      "end": 155.32,
      "text": "羽毛大概寓意着每个人"
    },
    {
      "start": 155.32,
      "end": 156.6,
      "text": "最珍贵的存在吧"
    }
  ]
}